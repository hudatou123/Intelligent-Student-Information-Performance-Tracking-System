# Database
DATABASE_URL=jdbc:postgresql://your-rds-endpoint:5432/student_tracking
DB_USERNAME=student_tracking
DB_PASSWORD=your_secure_password

# JWT
JWT_SECRET=your-256-bit-secret-key-here-change-this-in-production

# AI / LLM (Anthropic Claude via LangChain4j)
# Get a key from https://console.anthropic.com (separate from a Claude.ai subscription).
# Leave blank to use the built-in placeholder stub response.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# AWS (for local AWS CLI use)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Frontend
VITE_API_BASE_URL=https://your-backend-domain.com/api

# S3
S3_BUCKET_NAME=your-student-tracking-system-frontend-bucket

# CloudFront
CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id

# EC2
EC2_HOST=your-ec2-public-ip
